{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "build_data.py",
      "audit_categories.json",
      "DEPLOY.md",
      "README.md",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "data.js",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "**/*.@(js|css|svg|png)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ]
  }
}
